{
	"name": "gscode",
	"displayName": "GSCode",
	"description": "IntelliSense for Call of Duty: Black Ops III's GSC & CSC languages.",
	"icon": "icons/gscode.png",
	"version": "1.2.0",
	"publisher": "blakintosh",
	"repository": {
		"type": "git",
		"url": "https://github.com/Blakintosh/gscode"
	},
	"engines": {
		"vscode": "^1.65.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished",
		"workspaceContains:**/*.gsc",
		"workspaceContains:**/*.csc",
		"workspaceContains:**/*.gsh"
	],
	"main": "./out/extension.js",
	"contributes": {
		"semanticTokenScopes": [
			{
				"language": "gsc",
				"scopes": {
					"parameter.defaultLibrary": [
						"variable.language"
					],
					"variable.defaultLibrary": [
						"variable.language"
					]
				}
			},
			{
				"language": "csc",
				"scopes": {
					"parameter.defaultLibrary": [
						"variable.language"
					],
					"variable.defaultLibrary": [
						"variable.language"
					]
				}
			}
		],
		"languages": [
			{
				"id": "gsc",
				"aliases": [
					"GSC"
				],
				"extensions": [
					".gsc"
				],
				"configuration": "./language-configuration.json",
				"icon": {
					"dark": "./icons/file-gsc.png",
					"light": "./icons/file-gsc.png"
				}
			},
			{
				"id": "csc",
				"aliases": [
					"CSC"
				],
				"extensions": [
					".csc"
				],
				"configuration": "./language-configuration.json",
				"icon": {
					"dark": "./icons/file-csc.png",
					"light": "./icons/file-csc.png"
				}
			},
			{
				"id": "gsh",
				"aliases": [
					"GSH"
				],
				"extensions": [
					".gsh"
				],
				"configuration": "./language-configuration.json",
				"icon": {
					"dark": "./icons/file-gsh.png",
					"light": "./icons/file-gsh.png"
				}
			}
		],
		"commands": [],
		"grammars": [
			{
				"language": "gsc",
				"scopeName": "source.gsc",
				"path": "./syntaxes/gsc.tmGrammar.json"
			},
			{
				"language": "csc",
				"scopeName": "source.gsc",
				"path": "./syntaxes/gsc.tmGrammar.json"
			},
			{
				"language": "gsh",
				"scopeName": "source.gsc",
				"path": "./syntaxes/gsc.tmGrammar.json"
			}
		],
		"configuration": {
			"title": "GSCode",
			"properties": {
				"gscode.serverLogLevel": {
					"type": "string",
					"default": "off",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"description": "Controls the verbosity of logging from the GSCode language server. Set to 'off' to disable logging, 'messages' for basic information, or 'verbose' for detailed debug output.",
					"scope": "window"
				},
				"gscode.customRawPath": {
					"type": "string",
					"default": null,
					"description": "Custom path to the 'raw' folder for script path completions. Overrides automatic detection via TA_GAME_PATH.",
					"scope": "window"
				},
				"gscode.allowRawFolderWrites": {
					"type": "boolean",
					"default": false,
					"description": "Allow saving/modifying files in raw folders (default or custom). When disabled, you'll be warned when editing files in protected raw folders to prevent accidental modifications to vanilla game files.",
					"scope": "window"
				},
				"gscode.workspaceIndexingMode": {
					"type": "string",
					"default": "off",
					"enum": [
						"off",
						"partial",
						"full"
					],
					"enumDescriptions": [
						"Workspace indexing disabled. Only open files are analyzed.",
						"Fast indexing with signature analysis only. Provides symbol navigation and completions without diagnostics for unopened files. Recommended for large workspaces.",
						"Complete semantic analysis with diagnostics. Slower but provides full language features including diagnostics for all indexed files."
					],
					"description": "Controls workspace indexing. 'off' disables indexing, 'partial' performs fast signature analysis (recommended), 'full' runs complete semantic analysis with diagnostics.",
					"scope": "window"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^7.2.0",
		"@types/mocha": "^9.1.0",
		"@types/node": "14.x",
		"@types/vscode": "^1.65.0",
		"@typescript-eslint/eslint-plugin": "^5.16.0",
		"@typescript-eslint/parser": "^5.16.0",
		"@vscode/test-electron": "^2.1.3",
		"eslint": "^8.11.0",
		"glob": "^7.2.0",
		"mocha": "^9.2.2",
		"typescript": "^4.5.5"
	},
	"dependencies": {
		"dotenv": "^16.4.5",
		"stack-typescript": "^1.0.4",
		"vscode-languageclient": "^8.0.2",
		"vscode-languageserver": "^8.0.2",
		"vscode-nls": "^5.0.0",
		"vscode-textmate": "^6.0.0"
	}
}